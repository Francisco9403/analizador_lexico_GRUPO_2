package Parser;
import java.util.*;
import java_cup.runtime.*;
import Exception.SyntaxException;
import java.util.ArrayList;
import Lexer.Lexer;
import TablaSimbolo.TablaSimbolo;
class Parser;

parser code {:
    TablaSimbolo tablaSimbolos = Lexer.tablaSimbolos;

    public void syntax_error(Symbol s){
        // Esto solo imprime un aviso temporal en consola
        System.out.println("Aviso: Error sintáctico cerca de la línea " + (s.left + 1));
    }

    public void unrecovered_syntax_error(Symbol s) throws java.lang.Exception{
        // Construimos el mensaje y LANZAMOS la excepción
        String mensaje = "Error en la linea " + (s.left + 1) + " Columna " + s.right + ". Valor simbolo '" + s.value + "' no esperado.";

        // Lanzamos la excepción directamente
        throw new SyntaxException(mensaje);
    }
:};

terminal IF, ELIF, ELSE, WHILE, ALT_WHILE, BREAK, CONTINUE, PRINT;
terminal PROGRAM, DECLARE;
terminal String TYPE_INT, TYPE_FLOAT, TYPE_BOOL, TYPE_ARRAY;
terminal String READ_INT, READ_FLOAT, READ_BOOL, CONST_BOOL, CTE_ARREGLO;
terminal String ID, CTE_INT, CTE_FLOAT, CTE_STR;
terminal OP_SUMA, OP_RESTA, OP_MULT, OP_DIV;
terminal COMP_IGUAL, COMP_DISTINTO, COMP_MAYOR_IGUAL, COMP_MENOR_IGUAL, COMP_MAYOR, COMP_MENOR;
terminal ASIG, AND, OR, NOT;
terminal PAR_A, PAR_C, CORCH_A, CORCH_C, COMA, DOS_PUNTOS;
terminal V_INDENT, V_DEDENT, SUMA_ACUM;
terminal UMENOS;


/* --- DECLARACION DE NO TERMINALES --- */
nonterminal String program;
nonterminal String tipo;
nonterminal String seccion_declaracion, bloque_declaraciones, declaracion;
nonterminal ArrayList<String> lista_ids;
nonterminal String bloque_sentencias, sentencia, seccion_sentencias;
nonterminal String asignacion, impresion;
nonterminal String sentencia_if, sentencia_while;
nonterminal String expresion, lista_expresiones;

nonterminal String expresionOr, expresionAnd, expresionNot, expresionSumRes, expresionMultDiv, sum_acum, expresionMenosU;
nonterminal String comparacion, valorLiteral;
nonterminal String sentencia_control, bloque, lista_sentencias;
nonterminal String alt_while_part, final_if;

start with program;

/* --------------------------------------------------------
   1. ESTRUCTURA PRINCIPAL DEL PROGRAMA
   -------------------------------------------------------- */
program ::= seccion_declaracion:bd seccion_sentencias:bs
            {:
            RESULT = bd + "\n" + bs; :}
            | seccion_sentencias:bs
            {:
             RESULT= bs; :}
            ;

/* --------------------------------------------------------
   2. ZONA DE DECLARACION DE VARIABLES
   -------------------------------------------------------- */
seccion_declaracion ::= DECLARE bloque_declaraciones:bd {:
                    RESULT = bd; :}
                  | DECLARE
                  ;

bloque_declaraciones ::= bloque_declaraciones:bd declaracion:d{:
                        RESULT = bd + "\n" + d;
                      :}| declaracion:d {:
                        RESULT = d;
                       :} ;

declaracion ::= tipo:t DOS_PUNTOS lista_ids:l {:
            // Recorremos la lista y seteamos el tipo en la tabla
            for (String id : l) {
                tablaSimbolos.setType(id, t);
            }
            RESULT = t + " : " + l.toString();
        :};

lista_ids ::= lista_ids:l COMA ID:id {:
            l.add(id);
            RESULT = l;
        :}
        | ID:id {:
            ArrayList<String> lista = new ArrayList<>();
            lista.add(id);
            RESULT = lista;
        :};

tipo ::= TYPE_INT    {: RESULT = "INT"; :}
       | TYPE_FLOAT  {: RESULT = "FLOAT"; :}
       | TYPE_BOOL   {: RESULT = "BOOL"; :}
       | TYPE_ARRAY  {: RESULT = "FLOAT_ARRAY"; :}
       ;

/* --------------------------------------------------------
   3. ZONA DE SENTENCIAS (Cuerpo del programa)
   -------------------------------------------------------- */
seccion_sentencias ::= PROGRAM bloque_sentencias:bs{:
                    RESULT = bs;
                    :}| PROGRAM;

bloque_sentencias ::= bloque_sentencias:bs sentencia:s{:
                   RESULT = bs + "\n" + s;
                   :}| sentencia:s {:
                   RESULT = s;
                    :};

sentencia ::= asignacion:a{:
            RESULT= a;
          :}| impresion:i {:
            RESULT= i;
          :}| sentencia_if:si {:
            RESULT= si;
          :}| sentencia_while:sw{:
            RESULT= sw;
          :}| sentencia_control:sc{:
            RESULT= sc;
          :};

asignacion ::= ID ASIG expresionOr:e{:
              RESULT= e;
            :};

impresion ::= PRINT PAR_A expresionOr:e PAR_C{:
             RESULT = e;
           :}| PRINT PAR_A CTE_STR COMA expresionOr:e PAR_C{:
             RESULT = e;
           :}| PRINT PAR_A CTE_STR PAR_C
              ;

bloque ::= V_INDENT lista_sentencias:ls V_DEDENT{:
                  RESULT = ls;
                  :};

lista_sentencias ::= lista_sentencias:ls sentencia:s{: RESULT= ls + "\n" + s;:}
                  | sentencia:s {:RESULT = s;:}
                  ;

sentencia_control ::= BREAK
                    | CONTINUE
                    ;

sentencia_if ::= IF expresionOr:c bloque:b final_if:f {:
                     RESULT = c + "\n" + b + "\n" + f;
                 :};

final_if ::= ELIF expresionOr:c bloque:b final_if:f {:
                 RESULT = c + "\n" + b + "\n" + f;
             :}
           | ELSE bloque:b {:
                 RESULT = b;
             :}
           | /* vacío */ {:
                 RESULT = "";
             :}
           ;

sentencia_while ::= WHILE expresionOr:c bloque:b alt_while_part:aw {: RESULT= c + "\n" + b + "\n" + aw ;:} ;

/* Puede haber múltiples bloques ALT_WHILE */
alt_while_part ::= alt_while_part:aw ALT_WHILE expresionOr:c bloque:b {: RESULT= aw + "\n" + c + "\n" + b ;:}
                 | /* vacio */
                 ;
/* --------------------------------------------------------
   4. EXPRESIONES Y MATEMATICAS
   -------------------------------------------------------- */

expresionOr::= expresionAnd:ea OR expresionOr:eo {:
              RESULT = ea + "\n" + eo;
            :}| expresionAnd:ea{:
              RESULT = ea;
            :};

expresionAnd::= expresionNot:en AND expresionAnd:ea{:
              RESULT = en + "\n" + ea;
            :}| expresionNot:en{:
              RESULT = en;
            :};

expresionNot ::= NOT expresionNot:en{:
               RESULT = en ;
             :}| comparacion:c{:
               RESULT= c;
             :};


comparacion ::= expresionSumRes:es1 COMP_IGUAL expresionSumRes:es2 {: RESULT = es1 + "\n" + es2;:}
              | expresionSumRes:es1 COMP_DISTINTO expresionSumRes:es2 {: RESULT = es1 + "\n" + es2;:}
              | expresionSumRes:es1 COMP_MAYOR expresionSumRes:es2 {: RESULT = es1 + "\n" + es2;:}
              | expresionSumRes:es1 COMP_MENOR expresionSumRes:es2 {: RESULT = es1 + "\n" + es2;:}
              | expresionSumRes:es1 COMP_MAYOR_IGUAL expresionSumRes:es2 {: RESULT = es1 + "\n" + es2;:}
              | expresionSumRes:es1 COMP_MENOR_IGUAL expresionSumRes:es2 {: RESULT = es1 + "\n" + es2;:}
              | expresionSumRes:es {: RESULT = es;:}
              ;

expresionSumRes::=expresionSumRes:es OP_SUMA expresionMultDiv:em {: RESULT = es + "\n" + em;:}
                | expresionSumRes:es OP_RESTA expresionMultDiv:em {: RESULT = es + "\n" + em;:}
                | expresionMultDiv:em {: RESULT = em;:}
                ;

expresionMultDiv::=expresionMultDiv:em OP_MULT expresionMenosU:emu {: RESULT = em + "\n" + emu;:}
                 | expresionMultDiv:em OP_DIV expresionMenosU:emu {: RESULT = em + "\n" + emu;:}
                 | expresionMenosU:emu {: RESULT = emu;:}
                 ;

expresionMenosU::= OP_RESTA expresion:e {: RESULT = e;:} %prec UMENOS
                | expresion:e {: RESULT = e;:}
                ;

expresion ::= PAR_A expresionOr:e PAR_C {: RESULT = e;:}
            | ID
            | valorLiteral:vl {: RESULT = vl;:}
            /* FUNCIONES DE LECTURA */
            | ID CORCH_A expresionOr:e CORCH_C {: RESULT = e;:}
            | READ_INT PAR_A PAR_C
            | READ_FLOAT PAR_A PAR_C
            | READ_BOOL PAR_A PAR_C
            /* TEMA ESPECIAL GRUPO 2: Suma Acumulativa */
            | sum_acum:sm {: RESULT = sm;:}
            ;

valorLiteral ::= CTE_INT
              | CTE_FLOAT
              | CONST_BOOL
              | CTE_ARREGLO
              ;

sum_acum::= SUMA_ACUM PAR_A expresionOr:e COMA CORCH_A lista_expresiones:le CORCH_C PAR_C{:
            RESULT = e + "\n" + le;
            :}
          | SUMA_ACUM PAR_A expresionOr:e COMA CORCH_A CORCH_C PAR_C{:
            RESULT = e;
            :}
          | SUMA_ACUM PAR_A expresionOr:e COMA lista_expresiones:le PAR_C{:
            RESULT = e + "\n" + le;
            :};

/* --------------------------------------------------------
   5. ARREGLOS Y LISTAS
   -------------------------------------------------------- */

/*CORCH_A lista_expresiones CORCH_C
                  | CORCH_A CORCH_C ;  Arreglo vacio */

lista_expresiones ::= lista_expresiones:li COMA expresionOr:e{:
                    RESULT = li + "\n" + e;
                    :}| expresionOr:e{:
                    RESULT = e;
                    :};